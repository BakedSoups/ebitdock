project: {{ .Name }}

game:
  package: {{ .GamePackage }}
  output: {{ .GameOutput }}

wasm:
  exec: {{ .WASMExec }}
  build_flags:
    - -buildvcs=false

docker:
  compose_file: ./.ebitdock/compose.yaml
  go_image: golang:1.24

checks:
  before_rebuild:
    enabled: false
    command: go test {{ .GamePackage }}

services:
  web:
    root: {{ .StaticRoot }}
    port: {{ .WebPort }}
    image: nginx:1.27-alpine
    workdir: /usr/share/nginx/html
    volumes:
      - {{ .StaticRoot }}:/usr/share/nginx/html:ro
    ports:
      - name: web
        port: {{ .WebPort }}
        url: http://localhost:{{ .WebPort }}
    command: ""

  api:
    enabled: false
    command: go run ./server
    port: 3001
    image: golang:1.24
    workdir: /app
    volumes:
      - .:/app
    ports:
      - name: api
        port: 3001
        url: http://localhost:3001

dashboard:
  port: {{ .DashboardPort }}

watch:
  rebuild:
{{- range .WatchPatterns }}
    - {{ . }}
{{- end }}
  static:
{{- range .StaticPatterns }}
    - {{ . }}
{{- end }}
